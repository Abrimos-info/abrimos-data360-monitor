extends layout

block content
  main.d360-page.d360-page--picker
    section.d360-picker
      h1.d360-picker__title= _("picker.title", lang)
      p.d360-picker__lead= _("tagline", lang)
      ul.d360-picker__grid
        each link in countryLinks
          - var cname = _("chat.country." + link.iso, lang)
          li
            a.d360-picker__card(href="/" + link.slug)
              span.d360-picker__flag(aria-hidden="true")= countryFlag(link.iso)
              span.d360-picker__name= cname
