//- ====================================================================
//- Data360 Monitor — Pug mixins
//- ====================================================================
//- All mixins are pure: they accept an alert (or a primitive) and emit
//- HTML. No data access, no i18n calls beyond what callers pass in.
//- ====================================================================

//- Quality banner for incomplete / rejected PCN status.
mixin qualityBanner(alert, lang, _)
  if alert && (alert.quality_status === "incomplete" || alert.quality_status === "rejected")
    - var qKey = alert.quality_status === "rejected" ? "rejected" : "incomplete"
    div.d360-quality-banner(class=("d360-quality-banner--" + alert.quality_status) role="status")
      strong.d360-quality-banner__title= _("quality." + qKey + ".title", lang)
      p.d360-quality-banner__body= _("quality." + qKey + ".body", lang)

//- Country tag: flag emoji + localized name (no ISO3 suffix).
mixin countryTag(iso, lang, _)
  span.d360-country
    if iso && countryFlag
      span.d360-country__flag(aria-hidden="true")= countryFlag(iso)
    if _ && iso
      span.d360-country__name= _("chat.country." + iso, lang || "es")

//- Content-type badge: Noticia or Reportaje. Uses i18n locals helper `_`.
mixin contentTypeBadge(contentType, lang, _)
  - var lng = (lang === "en") ? "en" : "es"
  if contentType === 'reportaje'
    span.d360-badge.d360-badge--reportaje= (_ ? _("badge.reportaje", lng) : "Reportaje")
  else
    span.d360-badge.d360-badge--noticia= (_ ? _("badge.noticia", lng) : "Noticia")

//- Type chip: abrupt_change or anomaly. label is the visible text.
mixin typeChip(type, label)
  - var cls = (type === "abrupt_change") ? "abrupt" : "anomaly"
  span.d360-typechip(class=("d360-typechip--" + cls))
    span.d360-typechip__shape(aria-hidden="true")
      if type === "abrupt_change"
        svg(viewBox="0 0 10 10" width="10" height="10")
          path(d="M1 8 L4 4 L6 6 L9 2" stroke="currentColor" fill="none" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round")
      else
        svg(viewBox="0 0 10 10" width="10" height="10")
          path(d="M2 5 L4 5 M6 5 L8 5 M5 2 L5 8" stroke="currentColor" fill="none" stroke-width="1.3" stroke-linecap="round")
    span= label

//- Magnitude: signed, picks up/down/neutral color from sign.
mixin magnitude(text)
  - var sign = (typeof text === "string" && (text.charAt(0) === "+")) ? "up" : ((typeof text === "string" && (text.charAt(0) === "−" || text.charAt(0) === "-")) ? "down" : "neutral")
  span.d360-mag(class=("d360-mag--" + sign))= text

mixin langTag(code)
  span.d360-langtag= code

mixin observationDisplay(ev, lang)
  - var lng = (lang === "en") ? "en" : "es"
  if ev.observation && ev.observation.display
    = ev.observation.display[lng]
  else if ev.observation
    = ev.observation.value

//- Indicator code pill + full name (matches chat `.d360-ind-ref` pattern).
mixin indicatorRef(ind, lang, opts)
  if ind && ind.idno
    - opts = opts || {}
    - var unknown = _("indicators.date_unknown", lang)
    - var showDates = opts.dates !== false
    - var updatedText = ind.last_modified_display || unknown
    - var dataText = ind.last_data_display || unknown
    span.d360-ind-ref(class=(opts.block ? "d360-ind-ref--block" : ""))
      if ind.name && ind.name !== ind.idno
        span.d360-ind-name= ind.name
      span.d360-ind-pill
        code.d360-ind-pill__id= ind.idno
    if showDates
      span.d360-indicator-meta
        span.d360-indicator-meta__item
          span.d360-indicator-meta__label= _("indicators.updated_at", lang)
          if ind.last_modified_iso || ind.last_modified
            time.d360-local-datetime(datetime=(ind.last_modified_iso || ind.last_modified))
          else
            span= updatedText
        span.d360-indicator-meta__item
          span.d360-indicator-meta__label= _("indicators.last_data", lang)
          span= dataText

mixin indicatorRefFromAlert(alert, lang, opts)
  if alert && typeof indicatorFromAlert === "function"
    - var indRow = indicatorFromAlert(alert, lang)
    if indRow
      +indicatorRef(indRow, lang, opts)

//- Labeled data bar for article pages (value, magnitude, period, generation time).
mixin articleMetaBar(alert, lang, _)
  - var lng = (lang === "en") ? "en" : "es"
  - var magText = (alert.magnitude && alert.magnitude[lng]) || ''
  - var hasObs = alert.observation && (alert.observation.display || alert.observation.value != null)
  if hasObs || magText || alert.detected_at || alert.llm_debug
    div.d360-article__meta(role="group" aria-label=_ ? _("article.meta.group", lang) : "Detection data")
      if alert.detected_at
        div.d360-article__meta-item
          span.d360-article__meta-label= _ ? _("article.meta.generated_at", lang) : "Generated"
          time.d360-article__meta-value.d360-local-datetime(datetime=alert.detected_at)
      if alert.llm_debug && typeof formatLlmDebugSummary === "function"
        - var llmSummary = formatLlmDebugSummary(alert.llm_debug)
        - var llmTitle = typeof formatLlmDebugTitle === "function" ? formatLlmDebugTitle(alert.llm_debug) : ''
        if llmSummary
          div.d360-article__meta-item
            span.d360-article__meta-label= _ ? _("article.meta.llm", lang) : "Model"
            span.d360-article__meta-value(title=llmTitle)= llmSummary
      if hasObs
        div.d360-article__meta-item
          span.d360-article__meta-label= _ ? _("article.meta.value", lang) : "Value"
          span.d360-article__meta-value
            +observationDisplay(alert, lang)
      if magText
        div.d360-article__meta-item
          span.d360-article__meta-label= _ ? _("article.meta.magnitude", lang) : "Magnitude"
          span.d360-article__meta-value
            +magnitude(magText)
      if alert.observation
        - var periodText = alert.observation.period_narrative ? alert.observation.period_narrative[lng] : (alert.observation.period_display ? alert.observation.period_display[lng] : alert.observation.time_period)
        - var staleTip = alert.data_period_stale && _ ? _("detail.data_period_stale", lang) : null
        div.d360-article__meta-item(class=(alert.data_period_stale ? "d360-article__meta-item--stale" : ""))
          span.d360-article__meta-label= _ ? _("article.meta.period", lang) : "Period"
          span.d360-article__meta-value(title=staleTip)= periodText

mixin dataDateBadge(ev, lang, label, staleLabel)
  - var lng = (lang === "en") ? "en" : "es"
  - var text = ev.observation && ev.observation.period_narrative ? ev.observation.period_narrative[lng] : (ev.observation && ev.observation.period_display ? ev.observation.period_display[lng] : (ev.observation ? ev.observation.time_period : ""))
  - var staleTitle = ev.data_period_stale ? (staleLabel || label) : null
  span.d360-data-date(class=(ev.data_period_stale ? "d360-data-date--stale" : "") title=staleTitle)
    span.d360-data-date__label= label
    span.d360-data-date__value= text

mixin periodDisplay(ev, lang)
  - var lng = (lang === "en") ? "en" : "es"
  if ev.observation && ev.observation.period_display
    = ev.observation.period_display[lng]
  else if ev.observation
    = ev.observation.time_period

mixin citizenNarrative(ev, lang)
  - var lng = (lang === "en") ? "en" : "es"
  = (ev.lead && ev.lead[lng]) || ''

//- Verification mark. state: 'verified' | 'pending' | 'failed'.
//- Tip text is provided by caller for now (i18n later).
mixin verificationMark(state, tipTitle, tipDesc, size)
  - state = state || "verified"
  - size = size || 14
  - var color = (state === "verified") ? "var(--ok)" : ((state === "failed") ? "var(--err)" : "var(--warn)")
  span.d360-vmark(class=("d360-vmark--" + state) tabindex="0" role="img" aria-label=tipTitle)
    if state === "verified"
      svg(width=size height=size viewBox="0 0 14 14")
        circle(cx="7" cy="7" r="6" fill="none" stroke=color stroke-width="1.4")
        path(d="M4 7.2 L6.2 9.4 L10 5.6" stroke=color stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round")
    else if state === "pending"
      svg(width=size height=size viewBox="0 0 14 14")
        circle(cx="7" cy="7" r="6" fill="none" stroke=color stroke-width="1.4")
        path(d="M7 4 L7 7 L9 8.5" stroke=color stroke-width="1.4" fill="none" stroke-linecap="round")
    else
      svg(width=size height=size viewBox="0 0 14 14")
        circle(cx="7" cy="7" r="6" fill="none" stroke=color stroke-width="1.4")
        path(d="M4 4 L10 10 M10 4 L4 10" stroke=color stroke-width="1.4" stroke-linecap="round")
    span.d360-vmark__tip
      strong= tipTitle
      if tipDesc
        span= tipDesc

//- Sparkline chart. series is array of {period, value, is_change_point?, regional_avg?}.
//- Renders inline SVG, no external libraries.
mixin chart(series)
  if !series || !series.length
    div.d360-chart-empty (no series)
  else
    -
      var w = 520;
      var h = 140;
      var padL = 28, padR = 12, padT = 12, padB = 22;
      var innerW = w - padL - padR;
      var innerH = h - padT - padB;
      var values = series.map(function (p) { return p.value; });
      var avgs = series.filter(function (p) { return p.regional_avg !== undefined; }).map(function (p) { return p.regional_avg; });
      var allValues = values.concat(avgs);
      var minV = Math.min.apply(null, allValues);
      var maxV = Math.max.apply(null, allValues);
      var range = (maxV - minV) || 1;
      // Add 10% headroom
      var top = maxV + range * 0.1;
      var bot = minV - range * 0.1;
      var rangeAdj = top - bot;
      function x(i) { return padL + (series.length === 1 ? innerW / 2 : (i / (series.length - 1)) * innerW); }
      function y(v) { return padT + innerH - ((v - bot) / rangeAdj) * innerH; }
      var linePoints = series.map(function (p, i) { return x(i) + "," + y(p.value); }).join(" ");
      var avgPoints  = (avgs.length === series.length)
        ? series.map(function (p, i) { return x(i) + "," + y(p.regional_avg); }).join(" ")
        : null;
      var areaPath = "M " + x(0) + "," + y(bot) + " L " + linePoints.replace(/ /g, " L ") + " L " + x(series.length - 1) + "," + y(bot) + " Z";
    svg.d360-chart(viewBox=("0 0 " + w + " " + h) preserveAspectRatio="none" role="img" aria-label="Historical series")
      //- baseline axis
      line.d360-chart__axis(x1=padL x2=(w - padR) y1=(h - padB) y2=(h - padB))
      //- area under line
      path.d360-chart__area(d=areaPath)
      //- line
      polyline.d360-chart__line(points=linePoints)
      //- regional average (if any)
      if avgPoints
        polyline.d360-chart__avg(points=avgPoints)
      //- dots
      each p, i in series
        if p.is_change_point
          circle.d360-chart__dot.d360-chart__dot--cp(cx=x(i) cy=y(p.value) r="4")
        else
          circle.d360-chart__dot(cx=x(i) cy=y(p.value) r="2")
      //- axis labels: first, last, min, max periods
      text.d360-chart__label(x=padL y=(h - 6))= series[0].period
      text.d360-chart__label(x=(w - padR) y=(h - 6) text-anchor="end")= series[series.length - 1].period
      text.d360-chart__label(x="4" y=(y(maxV) + 3))= Math.round(maxV * 100) / 100
      text.d360-chart__label(x="4" y=(y(minV) + 3))= Math.round(minV * 100) / 100

//- Claim token: numeric value wrapped with PCN verification mark inline.
mixin claim(token, lang, state)
  - var display = (lang === "en") ? (token.display_en || String(token.value)) : (token.display_es || String(token.value))
  - var pcnState = state || (token.pcn_status === "rejected" ? "failed" : (token.pcn_status === "unverified" ? "pending" : (token.pcn_status === "verified" ? "verified" : "verified")))
  - var tipTitle = pcnState === "failed" ? (lang === "en" ? "Verification failed" : "Verificación fallida") : (pcnState === "pending" ? (lang === "en" ? "Unverified" : "Sin verificar") : (lang === "en" ? "Verified" : "Verificado"))
  - var tipDesc = token.pcn_reason || (pcnState === "verified" ? (lang === "en" ? "Mechanically checked against the source." : "Comprobado mecánicamente contra la fuente.") : null)
  - var claimCls = "d360-claim" + (pcnState === "failed" ? " d360-claim--failed" : (pcnState === "pending" ? " d360-claim--pending" : " d360-claim--verified"))
  span(class=claimCls data-claim-id=token.claim_id data-pcn-status=(token.pcn_status || pcnState))
    span.d360-claim__num= display
    +verificationMark(pcnState, tipTitle, tipDesc, 12)
