//- ====================================================================
//- Data360 Monitor — Card variants and feed
//- ====================================================================

include mixins

mixin cardNarrative(ev, lang, langMode, typeText, dataPeriodLabel, dataPeriodStaleLabel)
  - var langKey = (lang === "en") ? "en" : "es"
  article.d360-card.d360-card--narr(tabindex="0" role="button" data-alert-id=ev.id data-country=ev.country data-category=ev.category)
    div.d360-card__head
      div.d360-card__metaL
        +countryTag(ev.country)
        span.d360-card__divider ·
        span.d360-card__dataset= ev.indicator.idno
      div.d360-card__metaR
        +dataDateBadge(ev, lang, langMode, dataPeriodLabel, dataPeriodStaleLabel)
        +typeChip(ev.type, typeText)
    div.d360-card__body
      +citizenNarrative(ev, lang, langMode)
    div.d360-card__sub
      | #{ev.indicator.name[langKey]} ·
      +observationDisplay(ev, lang, langMode)
      |  ·
      +magnitude(ev.magnitude[langKey])

mixin cardNumber(ev, lang, langMode, typeText, dataPeriodLabel, dataPeriodStaleLabel)
  - var langKey = (lang === "en") ? "en" : "es"
  article.d360-card.d360-card--num(tabindex="0" role="button" data-alert-id=ev.id data-country=ev.country data-category=ev.category)
    div.d360-card__head
      div.d360-card__metaL
        +countryTag(ev.country)
        span.d360-card__divider ·
        span.d360-card__dataset= ev.indicator.idno
      div.d360-card__metaR
        +dataDateBadge(ev, lang, langMode, dataPeriodLabel, dataPeriodStaleLabel)
        +typeChip(ev.type, typeText)
    div.d360-card__body
      span.d360-card__bignum
        +observationDisplay(ev, lang, langMode)
      span.d360-card__bigtext
        = ev.indicator.name[langKey]
        |  ·
        +magnitude(ev.magnitude[langKey])

mixin cardNewspaper(ev, lang, langMode, typeText, dataPeriodLabel, dataPeriodStaleLabel)
  - var langKey = (lang === "en") ? "en" : "es"
  article.d360-card.d360-card--news(tabindex="0" role="button" data-alert-id=ev.id data-country=ev.country data-category=ev.category)
    div.d360-card__eyebrow
      +dataDateBadge(ev, lang, langMode, dataPeriodLabel, dataPeriodStaleLabel)
      span.d360-card__divider ·
      = ev.country
      |  ·
      = typeText
      |  ·
      = ev.indicator.idno
    h3.d360-card__headline
      +citizenNarrative(ev, lang, langMode)
    hr.d360-card__rule
    p.d360-card__lede
      | #{ev.indicator.name[langKey]} ·
      +observationDisplay(ev, lang, langMode)
      |  ·
      +magnitude(ev.magnitude[langKey])

mixin feed(events, variant, lang, langMode, _, typeTextFor)
  - variant = variant || "narr"
  - typeTextFor = typeTextFor || function(type) { return type === "abrupt_change" ? "Abrupt change" : "Anomaly"; }
  - var dataPeriodLabel = _("detail.data_period", lang)
  - var dataPeriodStaleLabel = _("detail.data_period_stale", lang)
  div.d360-feed
    each ev in events
      - var typeText = typeTextFor(ev.type)
      if variant === "num"
        +cardNumber(ev, lang, langMode, typeText, dataPeriodLabel, dataPeriodStaleLabel)
      else if variant === "news"
        +cardNewspaper(ev, lang, langMode, typeText, dataPeriodLabel, dataPeriodStaleLabel)
      else
        +cardNarrative(ev, lang, langMode, typeText, dataPeriodLabel, dataPeriodStaleLabel)
