extends layout

include cards
include mixins

block headerExtras
  - var variant = filters.variant || "narr"
  header.d360-header
    div.d360-header__top
      if lastUpdate
        div.d360-header__right
          div.d360-lastupdate
            span.d360-lastupdate__dot(aria-hidden="true")
            span.d360-lastupdate__label= _("ui.last_update", lang)
            span.d360-lastupdate__sep(aria-hidden="true") ·
            span.d360-lastupdate__time= lastUpdate
    div.d360-header__bar
      form.d360-filters(method="get" id="d360-filters-form")
        label.d360-filter
          span.d360-filter__label= _("ui.country", lang)
          select(name="country" id="d360-filter-country")
            option(value="ALL" selected=(filters.country === "ALL"))= _("ui.filter_all", lang)
            each iso in countries
              option(value=iso selected=(filters.country === iso)) #{countryFlag(iso)} #{_("chat.country." + iso, lang)}
        label.d360-filter
          span.d360-filter__label= _("ui.category", lang)
          select(name="category" id="d360-filter-category")
            option(value="ALL" selected=(filters.category === "ALL"))= _("ui.filter_all", lang)
            each cat in categories
              option(value=cat selected=(filters.category === cat))= cat
        label.d360-filter
          span.d360-filter__label= _("ui.content_type", lang)
          select(name="content_type" id="d360-filter-content-type" data-filter="content_type")
            option(value="ALL" selected=((filters.content_type || "ALL") === "ALL"))= _("ui.filter_all_types", lang)
            option(value="noticia" selected=(filters.content_type === "noticia"))= _("badge.noticia", lang)
            option(value="reportaje" selected=(filters.content_type === "reportaje"))= _("badge.reportaje", lang)
        label.d360-filter
          span.d360-filter__label= _("ui.card", lang)
          select(name="variant" id="d360-filter-variant")
            option(value="narr" selected=(variant === "narr")) Narrative
            option(value="num"  selected=(variant === "num"))  Number
            option(value="news" selected=(variant === "news")) Newspaper
      div.d360-eventcount
        strong#d360-event-count= visibleAlerts.length
        |  #{_("ui.events_count", lang)}

block content
  - var langKey = (lang === "en") ? "en" : "es"

  include partials/detail-panel

  main.d360-main
    div.d360-main__feed
      if allAlerts.length === 0
        div.d360-empty
          h2.d360-empty__title= _("ui.empty_title", lang)
          p.d360-empty__help= _("ui.empty_help", lang)
      else
        div.d360-feed
          - var dataPeriodLabel = _("detail.data_period", lang)
          - var dataPeriodStaleLabel = _("detail.data_period_stale", lang)
          - var indicatorsLabel = _("ui.indicators_covered", lang)
          each ev in allAlerts
            - var cardCountries = (Array.isArray(ev._countries) && ev._countries.length) ? ev._countries : (ev.country ? [ev.country] : [])
            - var cardCountryAttr = ev.country || (cardCountries[0] || '')
            - var countryHit = (filters.country === "ALL") || cardCountries.indexOf(filters.country) >= 0
            - var categoryHit = (filters.country !== "ALL" && false) || (filters.category === "ALL") || (filters.category === ev.category)
            - var typeHit = (!filters.content_type || filters.content_type === "ALL") || (ev.content_type === filters.content_type) || (ev.type === filters.content_type)
            - var hidden = !countryHit || !categoryHit || !typeHit
            - var typeText = ev.type ? ((ev.type === "abrupt_change") ? _("type.abrupt_change", lang) : _("type.anomaly", lang)) : null
            - var indName = (ev.indicator && ev.indicator.name && ev.indicator.name[langKey]) || (ev.indicator && ev.indicator.idno) || ev.dataset_id || ''
            - var indIdno = (ev.indicator && ev.indicator.idno) || ev.dataset_id || ''
            - var titleText = (ev.title && ev.title[langKey]) || ev._title || ev.id
            - var leadText = (ev.lead && ev.lead[langKey]) || ev._lead || ''
            - var magnitudeText = (ev.magnitude && ev.magnitude[langKey]) || ''
            - var indCount = Array.isArray(ev.indicators) ? ev.indicators.length : 0
            if ev.content_type === "reportaje"
              article.d360-card.d360-card--reportaje(class=(hidden ? "d360-card--hidden" : "") tabindex="0" role="button" data-alert-id=ev.id data-country=cardCountryAttr data-category=ev.category data-content-type="reportaje")
                div.d360-card__head
                  div.d360-card__metaL
                    each iso in cardCountries
                      +countryTag(iso, lang, _)
                    if cardCountries.length
                      span.d360-card__divider ·
                    span.d360-card__dataset= ev.dataset_id || ''
                  div.d360-card__metaR
                    +contentTypeBadge(ev.content_type, lang, _)
                h3.d360-card__headline= titleText
                p.d360-card__lede= leadText
                div.d360-card__footer
                  each iso in cardCountries
                    +countryTag(iso, lang, _)
                  if indCount
                    span.d360-card__divider ·
                    span.d360-card__indicators #{indCount} #{indicatorsLabel}
            else if variant === "num"
              article.d360-card.d360-card--num(class=(hidden ? "d360-card--hidden" : "") tabindex="0" role="button" data-alert-id=ev.id data-country=cardCountryAttr data-category=ev.category data-content-type=ev.content_type)
                div.d360-card__head
                  div.d360-card__metaL
                    +countryTag(ev.country, lang, _)
                    span.d360-card__divider ·
                    span.d360-card__dataset= indIdno
                  div.d360-card__metaR
                    if ev.observation
                      +dataDateBadge(ev, lang, dataPeriodLabel, dataPeriodStaleLabel)
                    +contentTypeBadge(ev.content_type, lang, _)
                    if ev.type
                      +typeChip(ev.type, typeText)
                div.d360-card__body
                  if ev.observation
                    span.d360-card__bignum
                      +observationDisplay(ev, lang)
                  span.d360-card__bigtext
                    = indName
                    if magnitudeText
                      |  ·
                      +magnitude(magnitudeText)
            else if variant === "news"
              article.d360-card.d360-card--news(class=(hidden ? "d360-card--hidden" : "") tabindex="0" role="button" data-alert-id=ev.id data-country=cardCountryAttr data-category=ev.category data-content-type=ev.content_type)
                div.d360-card__eyebrow
                  if ev.observation
                    +dataDateBadge(ev, lang, dataPeriodLabel, dataPeriodStaleLabel)
                    span.d360-card__divider ·
                  each iso in cardCountries
                    +countryTag(iso, lang, _)
                  span.d360-card__divider ·
                  +contentTypeBadge(ev.content_type, lang, _)
                  if typeText
                    |  ·
                    = typeText
                  |  ·
                  = indIdno
                h3.d360-card__headline= titleText
                hr.d360-card__rule
                p.d360-card__lede= leadText
                if ev.observation || magnitudeText
                  p.d360-card__sub
                    | #{indName}
                    if ev.observation
                      |  ·
                      +observationDisplay(ev, lang)
                    if magnitudeText
                      |  ·
                      +magnitude(magnitudeText)
            else
              article.d360-card.d360-card--narr(class=(hidden ? "d360-card--hidden" : "") tabindex="0" role="button" data-alert-id=ev.id data-country=cardCountryAttr data-category=ev.category data-content-type=ev.content_type)
                div.d360-card__head
                  div.d360-card__metaL
                    +countryTag(ev.country, lang, _)
                    span.d360-card__divider ·
                    span.d360-card__dataset= indIdno
                  div.d360-card__metaR
                    if ev.observation
                      +dataDateBadge(ev, lang, dataPeriodLabel, dataPeriodStaleLabel)
                    +contentTypeBadge(ev.content_type, lang, _)
                    if ev.type
                      +typeChip(ev.type, typeText)
                div.d360-card__body
                  = leadText
                div.d360-card__sub
                  | #{indName}
                  if ev.observation
                    |  ·
                    +observationDisplay(ev, lang)
                  if magnitudeText
                    |  ·
                    +magnitude(magnitudeText)

        div.d360-empty#d360-empty-filtered(style=(visibleAlerts.length === 0 ? "" : "display:none"))
          h2.d360-empty__title= _("ui.empty_filtered_title", lang)
          p.d360-empty__help= _("ui.empty_filtered_help", lang)

block scripts
  script.
    window.D360_ALERTS = !{JSON.stringify(allAlerts)};
    window.D360_FILTERS = !{JSON.stringify(filters)};
  script(src="/static/js/charts.js" defer)
  script(src="/static/js/chat-cards.js" defer)
  script(src="/static/js/alerts-feed.js" defer)
  script(src="/static/js/pcn-claims.js" defer)
  script(src="/static/js/detail-panel.js" defer)
  script(src="/static/js/behavior.js" defer)
