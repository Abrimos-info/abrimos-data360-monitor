div.d360-alert-chat
  div.d360-alert-chat__panel
    div.d360-alert-chat__messages#d360-alert-chat-messages(aria-live="polite" hidden)
    if articlePresets && articlePresets.length
      div.d360-alert-chat__presets#d360-alert-chat-presets(role="toolbar" aria-label=_("chat.article_presets_label", lang))
        each preset in articlePresets
          - var plabel = (lang === "en") ? preset.label_en : preset.label_es
          - var pprompt = (lang === "en") ? preset.prompt_en : preset.prompt_es
          button.d360-alert-chat__preset(type="button" data-prompt=pprompt)= plabel
    div.d360-alert-chat__composer
      form.d360-alert-chat__form#d360-alert-chat-form
        textarea.d360-alert-chat__input#d360-alert-chat-input(name="message" rows="2" placeholder=_("chat.placeholder", lang))
        button.d360-alert-chat__send#d360-alert-chat-send(type="submit" aria-label=_("chat.send", lang))= _("chat.send", lang)
