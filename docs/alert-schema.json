{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Data360 News Agent Content Item",
  "description": "A Noticia (per-indicator news story) or Reportaje (per-dataset investigative piece)",
  "oneOf": [
    { "$ref": "#/definitions/noticia" },
    { "$ref": "#/definitions/reportaje" }
  ],
  "definitions": {
    "bilingual": {
      "type": "object",
      "required": ["es", "en"],
      "properties": {
        "es": { "type": "string", "minLength": 1 },
        "en": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "claim_token": {
      "type": "object",
      "required": ["claim_id", "value"],
      "properties": {
        "claim_id": { "type": "string" },
        "value": { "type": "string" },
        "display_es": { "type": "string" },
        "display_en": { "type": "string" },
        "pcn_status": { "type": "string", "enum": ["verified", "rejected", "unverified"] },
        "pcn_reason": { "type": "string" },
        "pcn_source": { "type": "string" }
      }
    },
    "chart_point": {
      "type": "object",
      "required": ["period", "value"],
      "properties": {
        "period": { "type": "string" },
        "value": { "type": "number" }
      }
    },
    "llm_debug_step": {
      "type": "object",
      "required": ["phase", "provider", "provider_label", "model", "duration_ms", "input_tokens", "output_tokens"],
      "properties": {
        "phase": { "type": "string", "enum": ["narrate", "translate", "reportaje"] },
        "provider": { "type": "string" },
        "provider_label": { "type": "string" },
        "model": { "type": "string" },
        "duration_ms": { "type": "number", "minimum": 0 },
        "input_tokens": { "type": "number", "minimum": 0 },
        "output_tokens": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "llm_debug": {
      "type": "object",
      "required": ["provider", "provider_label", "model", "duration_ms", "input_tokens", "output_tokens", "steps"],
      "properties": {
        "provider": { "type": "string" },
        "provider_label": { "type": "string" },
        "model": { "type": "string" },
        "duration_ms": { "type": "number", "minimum": 0 },
        "input_tokens": { "type": "number", "minimum": 0 },
        "output_tokens": { "type": "number", "minimum": 0 },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/llm_debug_step" }
        }
      },
      "additionalProperties": false
    },
    "noticia": {
      "type": "object",
      "required": [
        "content_type", "id", "title", "lead", "story",
        "country", "dataset_id", "indicator",
        "claim_tokens", "verification_trace", "score", "detected_at"
      ],
      "properties": {
        "content_type": { "type": "string", "const": "noticia" },
        "id": { "type": "string" },
        "title": { "$ref": "#/definitions/bilingual" },
        "lead": { "$ref": "#/definitions/bilingual" },
        "story": { "$ref": "#/definitions/bilingual" },
        "country": { "type": "string", "enum": ["GTM", "HND", "ARG", "ECU", "MEX"] },
        "dataset_id": { "type": "string" },
        "indicator": {
          "type": "object",
          "required": ["idno", "database_id", "name"],
          "properties": {
            "idno": { "type": "string" },
            "database_id": { "type": "string" },
            "name": { "$ref": "#/definitions/bilingual" }
          }
        },
        "observation": {
          "type": "object",
          "properties": {
            "value": { "type": "string" },
            "time_period": { "type": "string" },
            "unit": { "type": "string" }
          }
        },
        "magnitude": { "type": "string" },
        "chart_series": {
          "type": "array",
          "items": { "$ref": "#/definitions/chart_point" }
        },
        "claim_tokens": { "type": "array", "items": { "$ref": "#/definitions/claim_token" } },
        "verification_trace": {
          "type": "object",
          "required": ["data360_dataset_url", "csv_link"],
          "properties": {
            "data360_dataset_url": { "type": "string", "format": "uri" },
            "csv_link": { "type": "string", "format": "uri" },
            "methodology_ref": { "type": "string" }
          }
        },
        "score": { "type": "number", "minimum": 0, "maximum": 1 },
        "detected_at": { "type": "string", "format": "date-time" },
        "data_period_stale": { "type": "boolean" },
        "license": { "type": "string" },
        "quality_status": { "type": "string", "enum": ["accepted", "incomplete", "rejected"] },
        "quality_tags": { "type": "array", "items": { "type": "string" } },
        "llm_debug": { "$ref": "#/definitions/llm_debug" }
      },
      "additionalProperties": false
    },
    "reportaje": {
      "type": "object",
      "required": [
        "content_type", "id", "title", "lead", "story",
        "country", "dataset_id", "indicators", "noticia_ids",
        "claim_tokens", "verification_trace", "score", "detected_at"
      ],
      "properties": {
        "content_type": { "type": "string", "const": "reportaje" },
        "id": { "type": "string" },
        "title": { "$ref": "#/definitions/bilingual" },
        "lead": { "$ref": "#/definitions/bilingual" },
        "story": { "$ref": "#/definitions/bilingual" },
        "country": { "type": "string", "enum": ["GTM", "HND", "ARG", "ECU", "MEX"] },
        "dataset_id": { "type": "string" },
        "indicators": { "type": "array", "items": { "type": "string" }, "minItems": 2 },
        "noticia_ids": { "type": "array", "items": { "type": "string" } },
        "claim_tokens": { "type": "array", "items": { "$ref": "#/definitions/claim_token" } },
        "verification_trace": {
          "type": "object",
          "required": ["data360_dataset_url"],
          "properties": {
            "data360_dataset_url": { "type": "string", "format": "uri" },
            "csv_links": { "type": "array", "items": { "type": "string", "format": "uri" } }
          }
        },
        "score": { "type": "number", "minimum": 0, "maximum": 1 },
        "detected_at": { "type": "string", "format": "date-time" },
        "license": { "type": "string" },
        "quality_status": { "type": "string", "enum": ["accepted", "incomplete", "rejected"] },
        "quality_tags": { "type": "array", "items": { "type": "string" } },
        "llm_debug": { "$ref": "#/definitions/llm_debug" }
      },
      "additionalProperties": false
    }
  }
}
