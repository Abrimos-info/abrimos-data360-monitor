{
  "name": "abrimos-data360-monitor",
  "version": "0.1.0",
  "description": "AI-powered news agency that detects newsworthy facts from Data360's 12,000 indicators and delivers them verified with local perspective to LAC newsrooms.",
  "license": "GPL-3.0-or-later",
  "type": "commonjs",
  "main": "data360-monitor.js",
  "scripts": {
    "start": "NODE_ENV=production node data360-monitor.js",
    "dev": "NODE_ENV=development node data360-monitor.js",
    "fetch:news": "node bin/fetch-news.js --no-preview --provider=gemini",
    "fetch:news:dynamic": "NEWS_FETCH_BODY=false GEMINI_NEWS_BATCH=true GEMINI_SEARCH_GROUNDING=false GEMINI_SKIP_COVERED=true node bin/fetch-news.js --no-preview --provider=gemini --watchlist-file data/dynamic-watchlist.json --max-per-indicator=2 --skip-covered",
    "fetch": "node bin/fetch-data.js",
    "fetch:probe": "node bin/fetch-data.js --probe-only",
    "discover": "node bin/discover-indicators.js",
    "analyze": "node bin/generate-analysis.js",
    "analyze:dynamic": "node bin/generate-analysis.js --changed-only",
    "analyze:dynamic:full": "node bin/generate-analysis.js",
    "analyze:all-tiers": "node bin/generate-analysis.js --all-tiers",
    "analyze:noticias": "node bin/generate-analysis.js --noticias-only",
    "analyze:reportajes": "node bin/generate-analysis.js --reportajes-only",
    "analyze:no-llm": "node bin/generate-analysis.js --no-llm",
    "build": "npm run fetch && npm run fetch:news && npm run analyze",
    "pipeline:dynamic": "node bin/pipeline-dynamic.js",
    "pipeline:dynamic:force": "node bin/pipeline-dynamic.js --force",
    "pipeline:dynamic:news-gdelt": "NEWS_FETCH_BODY=false node bin/fetch-news.js --no-preview --provider=gdelt --watchlist-file data/dynamic-watchlist.json --no-themes",
    "pipeline:dynamic:analyze": "npm run analyze:dynamic",
    "pretest": "node -e \"const fs=require('fs'),path=require('path');fs.mkdirSync('test/tmp',{recursive:true});const src=path.join('test','fixtures','analyses');const dst=path.join('data','analyses');if(fs.existsSync(src)){fs.mkdirSync(dst,{recursive:true});for(const f of fs.readdirSync(src)){if(f.endsWith('.md'))fs.copyFileSync(path.join(src,f),path.join(dst,f));}}\"",
    "test": "node --test test/*.test.js",
    "test:watch": "node --test --watch test/*.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Abrimos-info/abrimos-data360-monitor.git"
  },
  "author": "Abrimos.info <contacto@abrimos.info>",
  "bugs": {
    "url": "https://github.com/Abrimos-info/abrimos-data360-monitor/issues"
  },
  "homepage": "https://github.com/Abrimos-info/abrimos-data360-monitor#readme",
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "axios": "^1.16.1",
    "chokidar": "^4.0.3",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.6.1",
    "pug": "^3.0.3",
    "rss-parser": "^3.13.0"
  }
}
