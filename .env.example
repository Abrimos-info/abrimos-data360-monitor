# --- Server ---
D360_PORT=8090
NODE_ENV=development
MCP_URL=http://127.0.0.1:8021/mcp

# --- LLM provider ---
AI_PROVIDER=vllm
AI_ENABLED=true
# Legacy alias for AI_PROVIDER (optional)
# AI_MODE=vllm

# --- Anthropic API — when AI_PROVIDER=claude-code (recommended) ---
ANTHROPIC_API_KEY=
# ANTHROPIC_API_URL=https://api.anthropic.com
# ANTHROPIC_VERSION=2023-06-01
# ANTHROPIC_MODEL=claude-opus-4-20250514   # overrides CLAUDE_MODEL alias
CLAUDE_MODEL=opus
CLAUDE_MODEL_FALLBACKS=sonnet,haiku
# Optional: Claude Code CLI fallback when ANTHROPIC_API_KEY is unset
# CLAUDE_BIN=claude
# low | medium | high — CLI only (--effort=); ignored by Anthropic API
CLAUDE_EFFORT=

# --- LAIA / vLLM — when AI_PROVIDER=vllm ---
AI_API_URL=https://llms.laia.ar/v1
AI_API_KEY=
AI_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ
AI_MODEL_NOTICIA=Qwen/Qwen2.5-14B-Instruct-AWQ
AI_MODEL_TRANSLATE=Qwen/Qwen2.5-14B-Instruct-AWQ
AI_MODEL_REPORTAJE=Qwen/Qwen2.5-14B-Instruct-AWQ
AI_MODEL_NEWSLETTER=
NOTICIA_TRANSLATE=true
AI_SLIM_CONTEXT=true

# Timeouts and retries
AI_TIMEOUT_MS=120000
AI_CHAT_TIMEOUT_MS=300000
AI_REPORT_TIMEOUT_MS=300000
AI_FETCH_RETRIES=3
AI_TRACK_COSTS=true
# true: on Claude quota exhaustion, retry with vLLM
AI_FALLBACK_VLLM_ON_CLAUDE_QUOTA=false

# --- Analysis pipeline ---
# Skip LLM when detection fingerprint matches data/alerts/{IDNO}.meta.json
ANALYSIS_CHANGED_ONLY=false
# Cap noticias phase to top N indicators by |z| (0 = unlimited)
ANALYSIS_MAX_INDICATORS=0
# Max noticias per protagonist country per run/day (0 = unlimited; demo: 2)
ANALYSIS_MAX_NOTICIAS_PER_COUNTRY=0
# Max noticias total per run/day (0 = unlimited; demo: 10)
ANALYSIS_MAX_NOTICIAS_PER_RUN=0
# Replay (--as-of): true = only narrate indicators whose CSV last_modified matches that day
ANALYSIS_REPLAY_STRICT_BLOB=false
# Slim context size knobs (lower = fewer tokens)
CONTEXT_SLIM_SERIES_POINTS=8
CONTEXT_SLIM_BASELINE_INDICATORS=6
CONTEXT_SLIM_DATADICT_LINES=10

# --- Chat (scoped article + global) ---
CHAT_AI_PROVIDER=
CHAT_MAX_TURNS=8
# Max chars of data/analyses/{IDNO}.md injected into article chat system prompt
CHAT_GENERATION_CONTEXT_MAX_CHARS=48000

# --- Data360 ---
DATA360_API_BASE=https://data360api.worldbank.org
DATA360_FILES_BASE=https://data360files.worldbank.org
D360_DATA_DIR=
D360_DYNAMIC_WATCHLIST_PATH=

# --- OpenSearch (roadmap) ---
OPENSEARCH_URI=

# --- Email (newsletter roadmap) ---
BREVO_API_KEY=
BREVO_FROM_EMAIL=

# --- Gemini (news search, pool mode: 5 countries) ---
GEMINI_API_KEY=
# Pool: one Gemini call per country; GDELT fallback if Gemini fails or returns 0 accepted
NEWS_MODE=pool
NEWS_SKIP_COVERED=true
NEWS_MIN_ACCEPTED_PER_COUNTRY=8
NEWS_LOOKBACK_DAYS=30
NEWS_GDELT_FALLBACK=true
NEWS_GEMINI_FIRST=true
NEWS_MAX_ARTICLES_PER_COUNTRY=8
NEWS_MIN_GEMINI_ACCEPTED=1
# Gemini news discovery (prefer lite for free-tier RPM)
GEMINI_NEWS_MODEL=gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_FALLBACK=gemini-2.5-flash
GEMINI_PACE_MS=6000
GEMINI_MAX_RETRIES=3
# Fewer retries on 429 — fail fast instead of burning minutes per indicator
GEMINI_429_MAX_RETRIES=1
# Stop news phase after N consecutive 429 failures (quota exhausted)
GEMINI_ABORT_AFTER_429=3
# Skip Gemini calls for indicators that already have accepted headlines in the window
GEMINI_SKIP_COVERED=true
GEMINI_NEWS_MIN_ACCEPTED=1
# One Gemini call per indicator (all LAC countries) instead of 5× calls — default on
GEMINI_NEWS_BATCH=true
# On HTTP 429, do not burn quota retrying the fallback model
GEMINI_SKIP_FALLBACK_ON_429=true
# Cap GDELT indicator fallback after Gemini quota (pipeline default; replay uses fetch:news:fast without fallback)
GEMINI_GDELT_FALLBACK_MAX_INDICATORS=20
GEMINI_SEARCH_GROUNDING=true
# Append full Gemini prompt + raw_text + parsed JSON to data/news/raw/{COUNTRY}/responses.jsonl
GEMINI_SAVE_RAW=true
GEMINI_RESOLVE_GROUNDING_URLS=true
GEMINI_RESOLVE_TIMEOUT_MS=8000
# Default date window for Gemini news search (also overridable via fetch-news --from/--to)
GEMINI_NEWS_FROM=2026-04-01
GEMINI_NEWS_TO=2026-05-21
# Fall back to GDELT when Gemini fails
GEMINI_FALLBACK_TO_GDELT=true

# Fetch full article text from discovered URLs (HTTP, no extra Gemini tokens)
# Off in pipeline (headlines+URL are enough for reportaje context)
NEWS_FETCH_BODY=true
NEWS_ARTICLE_MAX_CHARS=2500
NEWS_ARTICLE_READ_BYTES=600000
NEWS_ARTICLE_TIMEOUT_MS=15000
NEWS_FETCH_USER_AGENT=

# GDELT pacing (when provider=gdelt or Gemini fallback)
GDELT_PACE_MS=8000
GDELT_MAX_ATTEMPTS=2
GDELT_FALLBACK_MAX_RECORDS=15

# --- NVIDIA NIM (optional) — analysis + chat inherit AI_PROVIDER when CHAT_AI_PROVIDER unset ---
# AI_PROVIDER=nvidia
# CHAT_AI_PROVIDER=nvidia
# NVIDIA_API_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_API_KEY=
# AI_MODEL_NVIDIA=moonshotai/kimi-k2.6

# --- Output ---
OUTPUT_DIR=./data
SUBSCRIBERS_TSV=./data/newsletter/subscribers.tsv
